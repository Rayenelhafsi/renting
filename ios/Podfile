# Uncomment this line to define a global platform for your project
platform :ios, '13.0'
inhibit_all_warnings!

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      config.build_settings['CODE_SIGNING_ALLOWED[sdk=iphonesimulator*]'] = 'NO'
      config.build_settings['CODE_SIGNING_REQUIRED[sdk=iphonesimulator*]'] = 'NO'
      config.build_settings['EXPANDED_CODE_SIGN_IDENTITY[sdk=iphonesimulator*]'] = ''
      config.build_settings['GCC_GENERATE_DEBUGGING_SYMBOLS'] = 'YES'
      config.build_settings['DEBUG_INFORMATION_FORMAT'] = 'dwarf-with-dsym' if ['Profile', 'Release'].include?(config.name)
      config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
      config.build_settings['SWIFT_SUPPRESS_WARNINGS'] = 'YES'
    end
  end

  flutter_local_notifications_headers = '"$(PODS_ROOT)/../.symlinks/plugins/flutter_local_notifications/ios/Classes"'
  Dir.glob(File.join(installer.sandbox.root, 'Target Support Files', 'Pods-Runner*', 'Pods-Runner*.xcconfig')).each do |xcconfig_path|
    xcconfig = File.read(xcconfig_path)
    next if xcconfig.include?(flutter_local_notifications_headers)

    xcconfig.gsub!(
      /^HEADER_SEARCH_PATHS = (.*)$/,
      "HEADER_SEARCH_PATHS = \\1 #{flutter_local_notifications_headers}"
    )
    File.write(xcconfig_path, xcconfig)
  end

  local_notifications_header = File.expand_path(
    File.join('..', '.symlinks', 'plugins', 'flutter_local_notifications', 'ios', 'Classes', 'FlutterLocalNotificationsPlugin.h'),
    __FILE__
  )
  if File.exist?(local_notifications_header)
    header = File.read(local_notifications_header)
    patched_header = header
      .gsub('setRegisterPlugins:', 'setPluginRegistrantCallback:')
      .gsub('FlutterPluginRegistrantCallback *)callback', 'FlutterPluginRegistrantCallback)callback')
    File.write(local_notifications_header, patched_header) if patched_header != header
  end

  Dir.glob(File.join(installer.sandbox.root, 'Target Support Files', 'Pods-Runner*', 'Pods-Runner-frameworks.sh')).each do |frameworks_script_path|
    script = File.read(frameworks_script_path)
    next if script.include?('Skipping static framework wrapper')

    patched_script = script.sub(
      "  if [ -L \"${source}\" ]; then\n    echo \"Symlinked...\"\n    source=\"$(readlink -f \"${source}\")\"\n  fi\n",
      "  if [ -L \"${source}\" ]; then\n    echo \"Symlinked...\"\n    source=\"$(readlink -f \"${source}\")\"\n  fi\n\n  local basename\n  basename=\"$(basename -s .framework \"$1\")\"\n  if [[ \"${source}\" == *.framework ]] && ! [ -r \"${source}/${basename}\" ]; then\n    echo \"Skipping framework wrapper without Mach-O binary: ${source}\"\n    rm -rf \"${destination}/${basename}.framework\"\n    return\n  fi\n  if [[ \"${source}\" == *.framework ]] && [[ \"$(file \"${source}/${basename}\")\" == *\"current ar archive\"* ]]; then\n    echo \"Skipping static framework wrapper: ${source}\"\n    rm -rf \"${destination}/${basename}.framework\"\n    return\n  fi\n"
    ).sub(
      "  local basename\n  basename=\"$(basename -s .framework \"$1\")\"\n  binary=\"${destination}/${basename}.framework/${basename}\"\n",
      "  binary=\"${destination}/${basename}.framework/${basename}\"\n"
    )

    File.write(frameworks_script_path, patched_script)
  end
end
